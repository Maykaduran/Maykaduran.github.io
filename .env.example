# Keystatic GitHub Mode Configuration
# Más info: https://keystatic.com/docs/github-mode

# Tu usuario y repo en GitHub (requerido por Keystatic)
PUBLIC_KEYSTATIC_REPO_OWNER=Maykaduran
PUBLIC_KEYSTATIC_REPO_NAME=Maykaduran.github.io

# GitHub OAuth App Credentials (para login si usas CMS)
# Solo si quieres acceder al panel de Keystatic en GitHub
KEYSTATIC_GITHUB_CLIENT_ID=tu_client_id
KEYSTATIC_GITHUB_CLIENT_SECRET=tu_client_secret

# Secreto para firmar cookies (puedes generar uno con: openssl rand -base64 32)
KEYSTATIC_SECRET=tu_secreto_aqui

# Public GitHub App Slug (opcional, solo si habilitas GitHub App Mode)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=tu_github_app_slug